---
/**
 * Hero.astro — Section d'accroche (RECONSTRUITE d'après la spec §9.1, pas de source).
 *
 *   [ badge « C'est quoi Notion Club ? » ]
 *   H1 : « Deviens le {Consultant Notion}[N] »
 *        « que les entreprises ont besoin. »
 *   sous-titre gris
 *   CTA « Rejoindre le Notion Club » → modal Fillout cnYDjzJD2bus
 *   social proof : 4 avatars + « +50 membres » + « ★ Noté à 8/10 »
 *
 * « Consultant Notion » en Instrument Serif Italic corail. Logo Notion inline.
 * Animations d'entrée : fade-up échelonné (tg-fadeup) + soulignement SVG (tg-draw).
 */
import CtaPill from '@components/ui/CtaPill.astro';

// Avatars social proof — PLACEHOLDER : ré-héberger les vraies photos membres.
const avatars = [
  'https://i.pravatar.cc/80?img=12',
  'https://i.pravatar.cc/80?img=32',
  'https://i.pravatar.cc/80?img=45',
  'https://i.pravatar.cc/80?img=5',
];
---

<section class="hero" id="hero">
  <div class="hero__inner">
    <span class="hero__badge tg-fadeup" style="--d: 0s">C'est quoi Notion Club ?</span>

    <h1 class="hero__title tg-fadeup" style="--d: 0.1s">
      Deviens le
      <span class="hero__serif">
        Consultant Notion
        <!-- Logo Notion inline (glyphe N encadré) -->
        <svg class="hero__notion" viewBox="0 0 24 24" aria-hidden="true" role="img">
          <rect x="1.5" y="1.5" width="21" height="21" rx="4" fill="#fff" stroke="#000" stroke-width="1.4" />
          <path d="M7 17V7l10 10V7" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <!-- Soulignement animé (tg-draw) -->
        <svg class="hero__underline" viewBox="0 0 300 12" preserveAspectRatio="none" aria-hidden="true">
          <path d="M2 8 C 80 2, 220 2, 298 7" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
        </svg>
      </span>
      <br />
      que les entreprises ont besoin.
    </h1>

    <p class="hero__subtitle tg-fadeup" style="--d: 0.25s">
      On t'accompagne à devenir expert sur Notion jusqu'à atteindre les
      5 000€ par mois.
    </p>

    <div class="hero__cta tg-fadeup" style="--d: 0.4s">
      <CtaPill label="Rejoindre le Notion Club" modal="fillout" filloutId="cnYDjzJD2bus" size="lg" />
    </div>

    <div class="hero__proof tg-fadeup" style="--d: 0.55s">
      <div class="hero__avatars">
        {avatars.map((src) => (
          <img src={src} alt="" width="36" height="36" loading="eager" />
        ))}
        <!-- PLACEHOLDER_AVATARS : remplacer par les vraies photos membres -->
      </div>
      <div class="hero__proof-text">
        <strong>+50 membres</strong>
        <span class="hero__rating">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.3 6.9.7-5.1 4.6 1.4 6.8L12 17.8 5.9 20.4l1.4-6.8L2.2 9l6.9-.7z" /></svg>
          Noté à 8/10
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 140px 20px 64px;
    text-align: center;
  }
  @media (min-width: 768px) {
    .hero {
      padding: 168px 24px 80px;
    }
  }

  .hero__inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    padding: 7px 18px;
    border-radius: var(--radius-pill);
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 28px;
  }

  .hero__title {
    font-size: clamp(34px, 6.5vw, 60px);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    line-height: 1.08;
    margin-bottom: 24px;
  }

  .hero__serif {
    position: relative;
    color: var(--accent);
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    white-space: nowrap;
  }

  .hero__notion {
    display: inline-block;
    vertical-align: -0.08em;
    width: 0.78em;
    height: 0.78em;
    margin-left: 0.12em;
  }

  .hero__underline {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.18em;
    width: 100%;
    height: 0.4em;
    color: var(--accent);
    stroke-dasharray: 320;
    stroke-dashoffset: 320;
    animation: tg-draw 1.1s var(--ease-signature) 0.7s forwards;
  }

  .hero__subtitle {
    font-size: clamp(16px, 2.4vw, 19px);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 540px;
    margin-bottom: 36px;
  }

  .hero__cta {
    margin-bottom: 32px;
  }

  .hero__proof {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .hero__avatars {
    display: flex;
  }
  .hero__avatars img {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid var(--page-bg);
    object-fit: cover;
    margin-left: -10px;
    background: var(--accent-soft);
  }
  .hero__avatars img:first-child {
    margin-left: 0;
  }
  .hero__proof-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    font-size: 14px;
    line-height: 1.3;
  }
  .hero__proof-text strong {
    font-weight: 600;
    color: var(--text-primary);
  }
  .hero__rating {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--text-muted);
    font-size: 13px;
  }
  .hero__rating svg {
    width: 13px;
    height: 13px;
    color: #f5a623;
  }

  /* ── Animations d'entrée ── */
  .tg-fadeup {
    opacity: 0;
    transform: translateY(20px);
    animation: tg-fadeup 0.8s var(--ease-signature) forwards;
    animation-delay: var(--d, 0s);
  }
  @keyframes tg-fadeup {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes tg-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tg-fadeup {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .hero__underline {
      animation: none;
      stroke-dashoffset: 0;
    }
  }
</style>
