// NOTE : la source utilise des <img> SVG distants (CloudFront), pas du SVG inline.
// Set 2 = duplication du Set 1 pour la boucle infinie.

const logos = [
  { src: "https://d1yei2z3i6k35z.cloudfront.net/1970629/69940fcb19485_lg1.svg", alt: "Logo 1" },
  { src: "https://d1yei2z3i6k35z.cloudfront.net/1970629/69940fd8eb2c9_lg2.svg", alt: "Logo 2" },
  { src: "https://d1yei2z3i6k35z.cloudfront.net/1970629/69940fe6839e8_lg3.svg", alt: "Logo 3" },
  { src: "https://d1yei2z3i6k35z.cloudfront.net/1970629/69940fef55a32_lg4.svg", alt: "Logo 4" },
  { src: "https://d1yei2z3i6k35z.cloudfront.net/1970629/6994100b4f070_lg5.svg", alt: "Logo 5" },
  { src: "https://d1yei2z3i6k35z.cloudfront.net/1970629/699410155b5e7_lg6.svg", alt: "Logo 6" },
  { src: "https://d1yei2z3i6k35z.cloudfront.net/1970629/6994101c7e019_lg7.svg", alt: "Logo 7" },
  { src: "https://d1yei2z3i6k35z.cloudfront.net/1970629/699410244c457_lg8.svg", alt: "Logo 8" },
  { src: "https://d1yei2z3i6k35z.cloudfront.net/1970629/6994102b88af4_lg9.svg", alt: "Logo 9" },
  { src: "https://d1yei2z3i6k35z.cloudfront.net/1970629/6994103379256_lg10.svg", alt: "Logo 10" },
