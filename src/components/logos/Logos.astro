---

<section class="logo-carousel-wrapper">
  <div class="logo-carousel-track" id="logoCarousel">
    {/* Set 1 */}
    {logos.map((logo) => (
      // PLACEHOLDER : logo SVG distant (CloudFront) — remplacer par un asset local si besoin
      <img src={logo.src} alt={logo.alt} class="logo-item" loading="lazy" />
    ))}
    {/* Set 2 : duplication pour boucle infinie */}
    {logos.map((logo) => (
      // PLACEHOLDER : logo SVG distant (CloudFront) — remplacer par un asset local si besoin
      <img src={logo.src} alt={logo.alt} class="logo-item" loading="lazy" />
    ))}
  </div>
</section>

<style>
  .logo-carousel-wrapper {
    width: 100%;
    overflow: hidden;
    position: relative;
    padding: 40px 0;
    margin-top: -50px;
    z-index: 1;
  }
  .logo-carousel-track {
    display: flex;
    gap: 60px;
    align-items: center;
  }
  .logo-item {
    height: 100px;
    width: auto;
    flex-shrink: 0;
    object-fit: contain;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    transform: translateZ(0);
  }
  @media (max-width: 768px) {
    .logo-item {
      height: 80px;
    }
    .logo-carousel-track {
      gap: 50px;
    }
  }
  @media (max-width: 480px) {
    .logo-item {
      height: 60px;
    }
    .logo-carousel-track {
      gap: 40px;
    }
    .logo-carousel-wrapper {
      padding: 20px 0;
    }
  }
</style>

<script>
  (function () {
    var track = document.getElementById("logoCarousel");
    if (!track) return;

    // prefers-reduced-motion : ne pas animer le marquee.
    var reduceMotion =
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduceMotion) return;

    var scrollPosition = 0;

    var isMobile = window.innerWidth <= 480;
    var isTablet = window.innerWidth > 480 && window.innerWidth <= 768;
    var scrollSpeed;

    if (isMobile) {
      scrollSpeed = 1.5;
    } else if (isTablet) {
      scrollSpeed = 2.2;
    } else {
      scrollSpeed = 2.5;
    }

    var gapSize = 60;
    var totalSetWidth = 0;
    var isAnimating = false;

    function init() {
      var logos = track.querySelectorAll(".logo-item");
      var loadedCount = 0;
      var totalLogos = logos.length / 2;

      function checkLoaded() {
        loadedCount++;
        if (loadedCount >= totalLogos) {
          for (var i = 0; i < totalLogos; i++) {
            totalSetWidth += logos[i].offsetWidth + gapSize;
          }
          if (!isAnimating) {
            isAnimating = true;
            startScrolling();
          }
        }
      }

      for (var i = 0; i < totalLogos; i++) {
        if (logos[i].complete) {
          checkLoaded();
        } else {
          logos[i].addEventListener("load", checkLoaded);
        }
      }
    }

    function startScrolling() {
      function animate() {
        scrollPosition += scrollSpeed;
        if (scrollPosition >= totalSetWidth) {
          scrollPosition = 0;
        }
        track.style.transform = "translateX(-" + scrollPosition + "px)";
        requestAnimationFrame(animate);
      }
      animate();
    }

    if (isMobile) {
      gapSize = 40;
    } else if (isTablet) {
      gapSize = 50;
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
