  { src: "https://d1yei2z3i6k35z.cloudfront.net/1970629/699410424f50f_lg12.svg", alt: "Logo 12" },
  { src: "https://d1yei2z3i6k35z.cloudfront.net/1970629/699410494d83e_lg13.svg", alt: "Logo 13" },
  { src: "https://d1yei2z3i6k35z.cloudfront.net/1970629/699410576c84d_lg14.svg", alt: "Logo 14" },
