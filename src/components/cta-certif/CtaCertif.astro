---
/**
 * CtaCertif.astro — CTA final « Certif Club » (RECONSTRUITE d'après la spec §9.3).
 *
 * Carte blanche, halo corail. Icône Notion à gauche, badge rond « FREE »
 * (rotation ~12°, coin haut-droit). Titre + texte + CTA « Rejoindre le bootcamp »
 * → modal Fillout ieyhzBxLQkus.
 */
import CtaPill from '@components/ui/CtaPill.astro';
---

<section class="certif" id="certif">
  <div class="certif__card">
    <span class="certif__badge" aria-hidden="true">FREE</span>

    <div class="certif__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <rect x="2" y="2" width="20" height="20" rx="4" fill="#fff" stroke="#000" stroke-width="1.4" />
        <path d="M7 17V7l10 10V7" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>

    <h2 class="certif__title">Pas encore prêt à nous rejoindre ?</h2>
    <p class="certif__text">
      On a lancé le Certif Club pour t'accompagner gratuitement à obtenir les
      certifications Notion.
    </p>

    <CtaPill label="Rejoindre le bootcamp" modal="fillout" filloutId="ieyhzBxLQkus" size="lg" />
  </div>
</section>

<style>
  .certif {
    padding: 56px 20px 72px;
    max-width: 880px;
    margin: 0 auto;
  }

  .certif__card {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding: 48px 28px 44px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }
  /* Halo corail derrière la carte */
  .certif__card::before {
    content: '';
    position: absolute;
    top: -40%;
    left: 50%;
    transform: translateX(-50%);
    width: 120%;
    height: 80%;
    background: radial-gradient(50% 50% at 50% 50%, rgba(224, 98, 90, 0.16), transparent 70%);
    pointer-events: none;
  }

  .certif__badge {
    position: absolute;
    top: 18px;
    right: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    transform: rotate(12deg);
    box-shadow: 0 6px 16px -4px rgba(224, 98, 90, 0.5);
  }

  .certif__icon {
    position: relative;
    width: 56px;
    height: 56px;
    margin: 0 auto 24px;
  }
  .certif__icon svg {
    width: 100%;
    height: 100%;
  }

  .certif__title {
    position: relative;
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 700;
    color: var(--text-heading);
    letter-spacing: -0.025em;
    margin-bottom: 14px;
  }
  .certif__text {
    position: relative;
    font-size: 16px;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 460px;
    margin: 0 auto 28px;
  }
</style>
