---
/**
 * BrandPill.astro — Pill noire avec dot corail qui clignote (dot-pulse).
 * Signature visuelle (ex. badge « disponible » / marque).
 */
export interface Props {
  label: string;
  class?: string;
}
const { label, class: extraClass } = Astro.props;
---

<span class:list={['brand-pill', extraClass]}>
  <span class="brand-pill__dot" aria-hidden="true"></span>
  {label}
</span>

<style>
  .brand-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    border-radius: var(--radius-pill);
    background: #000;
    color: #fff;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .brand-pill__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 rgba(224, 98, 90, 0.6);
    animation: dot-pulse 1.8s var(--ease-signature) infinite;
  }
  @keyframes dot-pulse {
    0% { box-shadow: 0 0 0 0 rgba(224, 98, 90, 0.6); }
    70% { box-shadow: 0 0 0 7px rgba(224, 98, 90, 0); }
    100% { box-shadow: 0 0 0 0 rgba(224, 98, 90, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .brand-pill__dot { animation: none; }
  }
</style>
