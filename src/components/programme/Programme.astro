  let activeModuleId = 1;

  function renderModules() {
    const grid = document.getElementById('modulesGrid');
    if (!grid) return;
    grid.innerHTML = modules
      .map((mod, index) => {
        const isActive = mod.id === activeModuleId;
        const num = (index + 1).toString().padStart(2, '0');
        return `
        <div class="module-row" data-module-id="${mod.id}">
            <span class="module-num">${num}</span>
            <div class="module-btn ${isActive ? 'module-btn-active' : ''}">
                <div class="shimmer"></div>
                <div class="icon-box">${icon(mod.icon)}</div>
                <span class="module-text">${mod.title}</span>
            </div>
        </div>`;
      })
      .join('');
    // Câblage des clics (remplace onclick inline du source)
    grid.querySelectorAll<HTMLElement>('.module-row').forEach((row) => {
      row.addEventListener('click', () => {
        const id = Number(row.dataset.moduleId);
        if (id) setActiveModule(id);
      });
    });
  }

  function renderContent() {
    const mod = modules.find((m) => m.id === activeModuleId);
    if (!mod) return;
    const titleEl = document.getElementById('detailTitle');
    const subEl = document.getElementById('detailSubtitle');
    if (titleEl) titleEl.innerHTML = mod.title;
    if (subEl) subEl.innerHTML = mod.subtitle;

    const contentContainer = document.querySelector<HTMLElement>('.key-content');
    if (contentContainer) {
      contentContainer.classList.remove('fade-in');
      void contentContainer.offsetWidth;
      contentContainer.classList.add('fade-in');
    }

    const pointsEl = document.getElementById('detailPoints');
    if (pointsEl) {
      pointsEl.innerHTML = mod.points
        .map(
          (point) => `
        <div class="point">
            <div class="point-check">${icon('solar:check-read-linear')}</div>
            <p>${point}</p>
        </div>`,
        )
        .join('');
    }

    const visualEl = document.getElementById('visualContainer');
    if (visualEl) {
      visualEl.innerHTML = mod.visual;
      // Replay animations on re-render (reset → reflow → restore)
      visualEl
        .querySelectorAll<HTMLElement>(
          '.animate-stamp-drop, .animate-doc-appear, .animate-progress-fill, .animate-badge-pop, .animate-check-draw',
        )
        .forEach((el) => {
          el.style.animation = 'none';
          void el.offsetWidth;
          el.style.animation = '';
        });
    }
  }

  function setActiveModule(id: number) {
    activeModuleId = id;
    renderModules();
    renderContent();

    // Scroll vers la carte de contenu sur mobile
    if (window.innerWidth < 768) {
      const card = document.querySelector<HTMLElement>('.nc-prog__panel-wrap');
      if (card) {
        setTimeout(() => {
          const navbar =
            document.getElementById('sio-nav') ||
            document.querySelector<HTMLElement>('.sio-menu-nav');
          const navbarOffset = navbar ? navbar.getBoundingClientRect().bottom + 16 : 100;
          const cardTop = card.getBoundingClientRect().top + window.scrollY - navbarOffset;
          window.scrollTo({ top: cardTop, behavior: 'smooth' });
        }, 50);
      }
    }
  }

  function init() {
    renderModules();
    renderContent();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
