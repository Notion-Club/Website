/* ══════ CARD 3 — SLACK ANIMATION ══════ */
.nc-sl-root{width:100%;max-width:380px;height:100%;min-height:0;position:relative;overflow:visible;display:flex;align-items:center;justify-content:center}

.nc-sl-msg{background:#fff;border-radius:12px;padding:16px;width:100%;box-shadow:0 1px 4px rgba(0,0,0,0.06);border:1px solid #f0f0f2;opacity:0;transform:translateY(12px);transition:opacity .5s cubic-bezier(.22,1,.36,1),transform .5s cubic-bezier(.22,1,.36,1)}
.nc-sl-msg.nc-sl-vis{opacity:1;transform:translateY(0)}
.nc-sl-head{display:flex;align-items:center;gap:10px;margin-bottom:8px}
