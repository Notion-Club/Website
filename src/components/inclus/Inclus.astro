.nc-fd-file::before{content:'';position:absolute;top:0;right:0;width:10px;height:10px;background:linear-gradient(225deg,#f1f5f9 45%,#e2e8f0 50%,transparent 50%);border-radius:0 6px 0 0}
</style>

<script>
(function() {
    // ══════ Shared visibility state ══════
    // Card 0 = base (always visible when scroll is in range)
    // Card 1 = ncS1 (progress), Card 2 = ncS2 (slack), Card 3 = ncS3
    var activeCard = 0;
    var prevActiveCard = -1;
    var onCardChange = [];

    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function boot() {
        var scroll     = document.getElementById('ncScroll');
        var sticky     = document.getElementById('ncSticky');
        var baseCard   = document.getElementById('ncBase');
        var stackCards = [
            document.getElementById('ncS1'),
            document.getElementById('ncS2'),
            document.getElementById('ncS3')
        ];
        var totalCards = 4;
        var segments   = totalCards - 1;
        if (!scroll || !sticky || !baseCard) return;

        // ══════ prefers-reduced-motion : pas de scroll-jacking ══════
        // On laisse les cartes empilées statiquement (état CSS par défaut) et on
        // n'attache pas le moteur de scroll.
        if (reduceMotion) {
            scroll.style.height = 'auto';
            return;
        }

        function layout() {
            scroll.style.height = (totalCards * 100) + 'vh';
            var headerH = document.querySelector('.nc-header').offsetHeight;
            var vh = window.innerHeight;
            var cardH = vh - headerH - 20;
            var isDesktop = window.innerWidth >= 768;
            cardH = Math.min(cardH, isDesktop ? 380 : 520);
            baseCard.style.height = cardH + 'px';
            stackCards.forEach(function(c) { if (c) c.style.height = cardH + 'px'; });
        }
        layout();
        var _rT;window.addEventListener('resize',function(){clearTimeout(_rT);_rT=setTimeout(layout,150)});

        stackCards.forEach(function(card, i) {
            if (!card) return;
            card.style.zIndex = 20 + (i * 10);
            card.style.transform = 'translateY(100%) scale(0.96)';
            card.style.opacity = '1';
            card.style.visibility = 'hidden';
        });

        function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

        var ticking = false;
        function onScroll() {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(function() {
                ticking = false;
                var rect = scroll.getBoundingClientRect();
                var scrolled = -rect.top;
                var totalDist = scroll.offsetHeight - window.innerHeight;
                if (totalDist <= 0) return;
                var progress = Math.max(0, Math.min(1, scrolled / totalDist));
                var walletOffset = 10;

                // Determine active card: the highest-index card that is visible (local > 0)
                // This means animation starts as soon as the card appears on screen
                var topCard = 0;
                for (var i = 0; i < segments; i++) {
                    var segStart = i / segments;
                    var segEnd = (i + 1) / segments;
                    var local = Math.max(0, Math.min(1, (progress - segStart) / (segEnd - segStart)));
                    if (local > 0) topCard = i + 1;
                }
                activeCard = topCard;

                // Fire change callbacks
                if (activeCard !== prevActiveCard) {
                    for (var c = 0; c < onCardChange.length; c++) {
                        onCardChange[c](activeCard, prevActiveCard);
                    }
                    prevActiveCard = activeCard;
                }

                for (var i = 0; i < segments; i++) {
                    var card = stackCards[i];
                    if (!card) continue;
                    var segStart = i / segments;
                    var segEnd = (i + 1) / segments;
                    var local = Math.max(0, Math.min(1, (progress - segStart) / (segEnd - segStart)));
                    var e = easeOut(local);
                    card.style.visibility = local > 0 ? 'visible' : 'hidden';
                    var landY = (i + 1) * walletOffset;
                    var tyPercent = 100 * (1 - e);
                    var sc = 0.96 + 0.04 * e;
                    card.style.transform = 'translate3d(0,calc(' + tyPercent.toFixed(1) + '% + ' + landY + 'px),0) scale(' + sc.toFixed(4) + ')';
                }
            });
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
    }

    // ══════ CARD 0 — iMESSAGE/MEET (CSS animation, pause/play) ══════
    function bootChat() {
        var root = document.querySelector('.nc-anim-root');
        if (!root) return;
        var animated = root.querySelectorAll('.nc-anim-imessage,.nc-anim-bubble-in,.nc-anim-bubble-out,.nc-anim-heart,.nc-anim-heart svg,.nc-anim-heart::before,.nc-anim-meet,.nc-anim-meet-win');
        // Pause all CSS animations initially, use a class
        root.style.setProperty('--nc-anim-state', 'paused');
        function setPlay(play) {
            root.style.setProperty('--nc-anim-state', play ? 'running' : 'paused');
        }
        setPlay(true); // Card 0 is visible by default
        onCardChange.push(function(now, prev) {
            setPlay(now === 0);
        });
    }

    // ══════ CARD 1 — PROGRESS ANIMATION ══════
    function bootProgress() {
        var COLORS = ['#e0625a','#f0a09c','#fcd5d3','#d4544d','#f7b8b4','#e8837c'];
        var CP_COUNT = 5;
        var STEP_MS = 700;
        var HOLD_MS = 300;
        var PAUSE_END = 800;
        var PAUSE_START = 400;
        var fill = document.getElementById('ncProgFill');
        var root = document.getElementById('ncProgRoot');
        if (!fill || !root) return;
        var cps = root.querySelectorAll('.nc-prog-cp');
        var running = false;
        var cancelled = false;

        function getTrackW() { return root.offsetWidth - 40; }
        function getPositions() {
            var tw = getTrackW(); var pos = [];
            for (var i = 0; i < CP_COUNT; i++) pos.push((i / (CP_COUNT - 1)) * tw);
            return pos;
        }
        function spawnConfetti(cp) {
            var container = cp.querySelector('.nc-prog-confetti');
            for (var i = 0; i < 10; i++) {
                var p = document.createElement('div');
                p.className = 'nc-prog-particle';
                var angle = (i / 10) * Math.PI * 2 + (Math.random() - 0.5) * 0.6;
                var dist = 20 + Math.random() * 22;
                var tx = Math.cos(angle) * dist;
                var ty = Math.sin(angle) * dist;
                var color = COLORS[Math.floor(Math.random() * COLORS.length)];
                var size = 3 + Math.random() * 3;
                var isRect = Math.random() > 0.5;
                p.style.cssText = 'width:'+size+'px;height:'+(isRect?size*1.8:size)+'px;border-radius:'+(isRect?'1px':'50%')+';background:'+color+';left:0;top:0;opacity:1;transform:translate(0,0) rotate(0deg) scale(1);transition:all 0.45s cubic-bezier(0.22,1,0.36,1);';
                container.appendChild(p);
                (function(el,x,y){requestAnimationFrame(function(){requestAnimationFrame(function(){el.style.transform='translate('+x+'px,'+y+'px) rotate('+(Math.random()*420)+'deg) scale(0.2)';el.style.opacity='0';})})})(p,tx,ty);
                setTimeout((function(el){return function(){el.remove()}})(p),500);
            }
        }
        function resetAll() {
            fill.style.transition = 'none';
            fill.style.width = '0px';
            fill.style.opacity = '1';
            cps.forEach(function(cp) {
                cp.classList.remove('nc-prog-active','nc-prog-done');
                cp.querySelector('.nc-prog-circle').style.opacity = '1';
                cp.querySelector('.nc-prog-circle').style.transition = '';
            });
        }
        function wait(ms) {
            return new Promise(function(r) { setTimeout(r, ms); });
        }
        function animateTo(index, positions) {
            return new Promise(function(resolve) {
                var tw = positions[index] + 21;
                fill.style.transition = 'width '+STEP_MS+'ms cubic-bezier(0.22,1,0.36,1)';
                fill.style.width = tw + 'px';
                setTimeout(function() {
                    if (cancelled) return resolve();
                    if (index > 0) { cps[index-1].classList.remove('nc-prog-active'); cps[index-1].classList.add('nc-prog-done'); }
                    cps[index].classList.add('nc-prog-active');
                    spawnConfetti(cps[index]);
                    setTimeout(resolve, HOLD_MS);
                }, STEP_MS);
            });
        }
        async function runCycle() {
            if (!running) return;
            cancelled = false;
            var positions = getPositions();
            resetAll();
            await wait(PAUSE_START);
            for (var i = 0; i < CP_COUNT; i++) {
                if (cancelled) return;
                await animateTo(i, positions);
            }
            if (cancelled) return;
            cps[CP_COUNT-1].classList.remove('nc-prog-active');
            cps[CP_COUNT-1].classList.add('nc-prog-done');
            await wait(PAUSE_END);
            if (cancelled) return;
            fill.style.transition = 'opacity 0.35s ease'; fill.style.opacity = '0';
            cps.forEach(function(cp) {
                cp.querySelector('.nc-prog-circle').style.transition = 'opacity 0.35s ease';
                cp.querySelector('.nc-prog-circle').style.opacity = '0';
            });
            await wait(400);
            if (cancelled) return;
            resetAll();
            await wait(200);
            if (running) runCycle();
        }
        function start() { if (running) return; running = true; cancelled = false; runCycle(); }
        function stop() { running = false; cancelled = true; resetAll(); }

        onCardChange.push(function(now) {
            if (now === 1) start(); else stop();
        });
    }

    // ══════ CARD 2 — SLACK ANIMATION ══════
    function bootSlack() {
        var MSG = 'Je viens de refaire mon LinkedIn, vous en pensez quoi ?';
        var HT=10, CT=6, RT=17;
        var textEl = document.getElementById('ncSlText');
        var msgEl = document.getElementById('ncSlMsg');
        var hcEl = document.getElementById('ncSlHeartC');
        var ccEl = document.getElementById('ncSlClapC');
        var rcEl = document.getElementById('ncSlRepC');
        var hR = document.getElementById('ncSlHeart');
        var cR = document.getElementById('ncSlClap');
        var rpEl = document.getElementById('ncSlReplies');
        if (!textEl || !msgEl) return;
        var running = false;
        var timeouts = [];

        function st(fn, ms) { var t = setTimeout(fn, ms); timeouts.push(t); return t; }
        function clearAll() { timeouts.forEach(clearTimeout); timeouts = []; }

        function prep() { textEl.innerHTML = ''; for (var i = 0; i < MSG.length; i++) { var s = document.createElement('span'); s.textContent = MSG[i] === ' ' ? ' ' : MSG[i]; textEl.appendChild(s); } }
        function cnt(el, t, d) { var start = performance.now(); function tick(n) { if (!running) return; var p = Math.min(1, (n - start) / d); el.textContent = Math.round((1 - Math.pow(1 - p, 3)) * t); if (p < 1) requestAnimationFrame(tick); } requestAnimationFrame(tick); }
        function reveal(cb) { var spans = textEl.querySelectorAll('span'); var i = 0; function next() { if (!running) return; if (i < spans.length) { spans[i].classList.add('nc-sl-shown'); i++; st(next, 25); } else if (cb) st(cb, 200); } next(); }
        function reset() {
            clearAll();
            msgEl.classList.remove('nc-sl-vis');
            hR.classList.remove('nc-sl-vis');
            cR.classList.remove('nc-sl-vis');
            rpEl.classList.remove('nc-sl-vis');
            hcEl.textContent = '0'; ccEl.textContent = '0'; rcEl.textContent = '0';
            msgEl.style.transition = ''; msgEl.style.opacity = '';
            prep();
        }
        function fadeOut(cb) { msgEl.style.transition = 'opacity .4s ease'; msgEl.style.opacity = '0'; st(function() { msgEl.style.transition = ''; msgEl.style.opacity = ''; cb(); }, 500); }

        function run() {
            if (!running) return;
            reset();
            st(function() {
                if (!running) return;
                msgEl.classList.add('nc-sl-vis');
                st(function() {
                    if (!running) return;
                    reveal(function() {
                        if (!running) return;
                        hR.classList.add('nc-sl-vis');
                        st(function() { cR.classList.add('nc-sl-vis'); }, 150);
                        cnt(hcEl, HT, 800);
                        st(function() { cnt(ccEl, CT, 600); }, 200);
                        st(function() { if (!running) return; rpEl.classList.add('nc-sl-vis'); cnt(rcEl, RT, 900); }, 300);
                        st(function() { if (!running) return; fadeOut(function() { st(run, 300); }); }, 3000);
                    });
                }, 400);
            }, 200);
        }

        function start() { if (running) return; running = true; run(); }
        function stop() { running = false; reset(); }

        onCardChange.push(function(now) {
            if (now === 2) start(); else stop();
        });
    }

    // ══════ CARD 3 — FOLDER ANIMATION ══════
    function bootFolder() {
        var cursor = document.getElementById('ncFdCursor');
        var folder = document.getElementById('ncFdFolder');
        var files = document.querySelectorAll('.nc-fd-file');
        var root = document.getElementById('ncFdRoot');
        if (!cursor || !folder || !root) return;
        var running = false;
        var cancelled = false;

        function wait(ms) { return new Promise(function(r) { setTimeout(r, ms); }); }

        function moveCursor(x, y, dur) {
            cursor.style.transition = 'left ' + dur + 'ms cubic-bezier(0.22,1,0.36,1),top ' + dur + 'ms cubic-bezier(0.22,1,0.36,1)';
            cursor.style.left = x + 'px';
            cursor.style.top = y + 'px';
        }

        function resetFiles() {
            files.forEach(function(f) { f.classList.remove('nc-fd-shown', 'nc-fd-gather'); f.style.transitionDelay = '0s'; });
        }

        function reset() {
            cancelled = true;
            folder.classList.remove('nc-fd-open');
            resetFiles();
            cursor.classList.remove('nc-fd-vis');
            cursor.style.transition = 'none';
            cursor.style.left = (root.offsetWidth + 30) + 'px';
            cursor.style.top = (root.offsetHeight * 0.7) + 'px';
        }

        async function run() {
            if (!running) return;
            cancelled = false;
            reset();
            cancelled = false;
            var cx = root.offsetWidth / 2;
            var cy = root.offsetHeight / 2;

            await wait(400);
            if (cancelled) return;

            cursor.classList.add('nc-fd-vis');
            await wait(50);
            if (cancelled) return;
            moveCursor(cx + 10, cy - 10, 700);
            await wait(800);
            if (cancelled) return;

            cursor.classList.remove('nc-fd-vis');
            await wait(200);
            if (cancelled) return;

            folder.classList.add('nc-fd-open');
            await wait(400);
            if (cancelled) return;

            files.forEach(function(f, i) {
                f.style.transitionDelay = (i * 80) + 'ms';
                f.classList.add('nc-fd-shown');
            });
            await wait(2200);
            if (cancelled) return;

            files.forEach(function(f, i) {
                f.style.transitionDelay = (i * 50) + 'ms';
                f.classList.remove('nc-fd-shown');
                f.classList.add('nc-fd-gather');
            });
            await wait(600);
            if (cancelled) return;

            folder.classList.remove('nc-fd-open');
            resetFiles();
            await wait(800);

            if (running) run();
        }

        function start() { if (running) return; running = true; cancelled = false; run(); }
        function stop() { running = false; reset(); }

        onCardChange.push(function(now) {
            if (now === 3) start(); else stop();
        });
    }

    function init() {
        boot();
        bootChat();
        bootProgress();
        bootSlack();
        bootFolder();
    }

    if (document.readyState === 'complete') init();
    else window.addEventListener('load', init);
})();
</script>
