.nc-fd-cursor{position:absolute;z-index:20;width:18px;height:22px;opacity:0;pointer-events:none;filter:drop-shadow(0 1px 2px rgba(0,0,0,0.2));transition:opacity 0.3s ease}
.nc-fd-cursor.nc-fd-vis{opacity:1}
