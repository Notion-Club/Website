.nc-sl-text span.nc-sl-shown{opacity:1}
.nc-sl-reactions{display:flex;align-items:center;gap:6px;margin-bottom:10px;min-height:28px}
.nc-sl-react{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:12px;background:#f8f8f8;border:1px solid #e8e8ec;font-size:12px;opacity:0;transform:scale(0.8);transition:opacity .3s cubic-bezier(.22,1,.36,1),transform .3s cubic-bezier(.34,1.56,.64,1)}
.nc-sl-react.nc-sl-vis{opacity:1;transform:scale(1)}
.nc-sl-react-emoji{font-size:12px;line-height:1}
